VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# NUNCA usar prefixo VITE_ na service role key — seria exposta no bundle JS do frontend
# Usar apenas em scripts server-side, migrations, e Edge Functions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DATABASE connection used by migration runner (optional locally)
# Example (percent-encode special chars in password):
# postgresql://postgres:Thi%40supabase1@db.uxnfknlwaebpyadrsojm.supabase.co:5432/postgres
DATABASE_URL=

# Optional local overrides for psql connection
# PGHOST=
# PGUSER=
# PGPASSWORD=
# PGPORT=5432
# PGDATABASE=postgres
